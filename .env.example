# Azure Speech (STT + TTS)
AZURE_SPEECH_KEY=your_key_here
AZURE_SPEECH_REGION=eastasia

# LLM (OpenAI-compatible API)
LLM_API_KEY=your_key_here
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_MODEL=mimo-v2.5-pro
LLM_MAX_TOKENS=150       # Max tokens per response (lower = faster/cheaper)
LLM_MAX_HISTORY=5        # Past exchanges to remember (0 = unlimited)

# VRChat OSC
VRC_CHATBOX_IP=127.0.0.1
VRC_CHATBOX_PORT=9000

# Audio
AUDIO_DEVICE_INDEX=-1    # -1 = default; list devices with: python main.py --list-devices

# System prompt (customize the AI personality)
SYSTEM_PROMPT=You are a playful, witty AI companion. Be fun, slightly chaotic, but kind. Keep responses short.

# STT tuning
STT_SILENCE_THRESHOLD=500       # Amplitude threshold (500 = medium sensitivity)
STT_SILENCE_CUTOFF_SEC=2.0     # Seconds of silence before transcribing
STT_CAPTURE_MODE=microphone    # loopback | microphone

# Wake word detection mode
# vosk = Vosk keyphrase (any phrase, requires: pip install vosk)
# vad = energy VAD + text filter (requires STT for every sound)
# openwakeword = classifier model (requires: pip install openwakeword + model file)
USE_WAKE_WORD=vosk

# Trigger phrase — used by Vosk keyphrase spotting or VAD text filter.
# Not used in openWakeWord mode (model filename defines the keyword).
WAKE_KEYWORD=computer

# openWakeWord model name (e.g. "Amelia" for models/openwakeword/Amelia.onnx)
# Only used when USE_WAKE_WORD=openwakeword
OWW_MODEL=

# TTS output device UUID (empty = default speaker)
# Find UUID: pip install comtypes pycaw; python resolve_devices.py <index>
# Then: pip uninstall comtypes pycaw psutil -y
TTS_OUTPUT_DEVICE_UUID=
TTS_PITCH=0              # Pitch adjustment (e.g., 35 = +35%)

# Vision / Screen Capture (uses main LLM model, trigger-based)
VISION_TRIGGER_PHRASE=look at this
VISION_CAPTURE_WINDOW=VRChat

# Web UI
WEB_HOST=0.0.0.0
WEB_PORT=5000
