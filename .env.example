# Azure Speech (STT + TTS)
AZURE_SPEECH_KEY=your_key_here
AZURE_SPEECH_REGION=eastasia

# LLM via OpenCode Go (OpenAI-compatible API)
OPENCODE_GO_API_KEY=your_key_here
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_MODEL=mimo-v2.5-pro
# Available models: GLM-5, GLM-5.1, Kimi K2.5, Kimi K2.6, MiMo-V2.5,
#   MiMo-V2.5-Pro, MiniMax M2.5, MiniMax M2.7, Qwen3.5 Plus, Qwen3.6 Plus,
#   DeepSeek V4 Pro, DeepSeek V4 Flash
# Recommended: qwen3.6-plus (only model that works with full responses)
# Benchmarked: deepseek-v4-flash/glm-5.1 return empty, kimi-k2.6 is robotic

# VRChat OSC
VRC_CHATBOX_IP=127.0.0.1
VRC_CHATBOX_PORT=9000

# Audio
AUDIO_DEVICE_INDEX=-1   # -1 = default; list devices with: python main.py --list-devices

# System prompt
SYSTEM_PROMPT=You are a playful, witty AI companion. Be fun, slightly chaotic, but kind. Keep responses short (1-3 sentences). You're chatting with people in VRChat.

# STT tuning
STT_SILENCE_THRESHOLD=500       # Amplitude threshold for silence detection (500 = medium sensitivity)
STT_SILENCE_CUTOFF_SEC=2.0     # Seconds of silence before transcribing
STT_CAPTURE_MODE=loopback       # loopback (captures desktop/VRChat audio) | microphone

# TTS output device (leave empty for default speaker)
TTS_OUTPUT_DEVICE=             # e.g., "CABLE Input" for VB-CABLE
