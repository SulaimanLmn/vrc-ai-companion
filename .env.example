# Azure Speech (STT + TTS)
AZURE_SPEECH_KEY=your_key_here
AZURE_SPEECH_REGION=eastasia

# LLM via OpenCode Go (OpenAI-compatible API)
OPENCODE_GO_API_KEY=your_key_here
OPENCODE_GO_BASE_URL=http://localhost:8080/v1
# Change to your actual OpenCode Go URL if different
OPENCODE_GO_MODEL=gpt-4o-mini

# VRChat OSC
VRC_CHATBOX_IP=127.0.0.1
VRC_CHATBOX_PORT=9000

# Audio
AUDIO_DEVICE_INDEX=-1   # -1 = default; list devices with: python main.py --list-devices

# System prompt
SYSTEM_PROMPT=You are a playful, witty AI companion. Be fun, slightly chaotic, but kind. Keep responses short (1-3 sentences). You're chatting with people in VRChat.
